# ── Copia este fichero como .env y rellena los valores ────────────────────────
# cp .env.example .env

# Clave secreta de Flask (genera una con: python3 -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=cambia-esto-por-una-clave-aleatoria-larga

# URL pública de la aplicación (para los enlaces en los correos de notificación)
APP_URL=http://tu-dominio.com

# ── Correo saliente (SMTP) ─────────────────────────────────────────────────────
# Ejemplo con Gmail:
#   MAIL_SERVER=smtp.gmail.com
#   MAIL_PORT=587
#   MAIL_USERNAME=tu@gmail.com
#   MAIL_PASSWORD=tu-contrasena-de-aplicacion
#   MAIL_USE_TLS=true
#
# Ejemplo con un servidor SMTP propio:
#   MAIL_SERVER=mail.tu-empresa.com
#   MAIL_PORT=587
#   MAIL_USERNAME=soporte@tu-empresa.com
#   MAIL_PASSWORD=tu-contrasena
#   MAIL_USE_TLS=true

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu@correo.com
MAIL_PASSWORD=tu-contrasena-de-aplicacion
MAIL_USE_TLS=true

# Correo donde el equipo de sistemas recibe las alertas de nuevos tickets
ADMIN_EMAIL=sistemas@tu-empresa.com
